    data = await get_balance()
    if not data:
        return {"error": "API 키가 없거나 인증 실패. /api/trading/keys 로 키를 먼저 설정하세요."}
    # KRW + 보유 코인만 필터
    result = [
        {
            "currency": d["currency"],
            "balance": float(d["balance"]),
            "locked": float(d.get("locked", 0)),
            "avg_buy_price": float(d.get("avg_buy_price", 0)),
        }
        for d in data
    ]
    return result


@app.post("/api/trading/order")
async def api_place_order(req: OrderRequest):
    """주문 집행 (매수/매도)"""
    result = await place_order(
        market=req.market,
        side=req.side,
        ord_type=req.ord_type,
        price=req.price,
        volume=req.volume,
    )
    return result


@app.get("/api/trading/orders")
async def api_orders(state: str = "wait"):
    """주문 목록 조회"""
    return await get_orders(state=state)


@app.delete("/api/trading/order/{uuid_str}")
async def api_cancel_order(uuid_str: str):
    """주문 취소"""
    return await cancel_order(uuid_str)


if __name__ == "__main__":
    uvicorn.run("main:app", host="0.0.0.0", port=5001, reload=True)
