@app.get("/api/indicator/full/{market}")
async def api_indicator_full(market: str, exchange: str = "upbit"):
    """70여 종 기술 지표 정밀 계산 결과"""
    if exchange == "upbit":
        candles = await get_candles(market, unit=1, count=100)
    else:
        candles = await get_klines(market, interval="1m", limit=100)
    return indicator_engine.calculate_all(candles)


# ───────────────────────────────────────
# WebSocket — 실시간 브로드캐스트
# ───────────────────────────────────────
@app.websocket("/ws/live")
async def ws_live(websocket: WebSocket):
    await websocket.accept()
    connected_clients.append(websocket)
    try:
        if upbit_cache:
            await websocket.send_json({"type": "init_upbit", "data": list(upbit_cache.values())})
        if binance_cache:
            await websocket.send_json({"type": "init_binance", "data": list(binance_cache.values())})
        while True:
            await websocket.receive_text()
    except WebSocketDisconnect:
        if websocket in connected_clients:
            connected_clients.remove(websocket)


