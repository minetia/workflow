        return list(upbit_cache.values())
    # 캐시 없으면 REST로 직접 조회
    data = await get_ticker()
    return [
        {
            "market": d["market"],
            "price": d["trade_price"],
            "change_rate": round(d["signed_change_rate"] * 100, 2),
            "change": d["change"],
            "volume_24h": d["acc_trade_volume_24h"],
            "source": "upbit"
        }
        for d in data
    ]


