@app.get("/api/vault/status")
async def get_vault_status():
    """실전 사령관 금고 상태 조회 (API 연동 데이터만 표시)"""
    balances = await get_balance()
    if not balances:
        return {"error": "API Key Required", "reality_sync": "0%"}
    
    # KRW 잔고 합산
    total_krw = 0
    btc_balance = 0
    for b in balances:
        if b['currency'] == 'KRW':
            total_krw = float(b['balance'])
        if b['currency'] == 'BTC':
            btc_balance = float(b['balance'])

    return {
        "virtual": btc_balance,
        "real": total_krw,
        "lord_wallet": {
            "address": "PHX-HUB-SECURE-ENTRY",
            "access": "MASTER"
        },
        "initial_seed": 0,
        "tax_rate": "0%",
        "vault_allocation": "0%",
        "reality_sync": "100_PERCENT"
    }


