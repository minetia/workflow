@app.get("/api/ai/signal/{market}")
async def api_ai_signal(market: str, exchange: str = "upbit"):
    """AI 신호 조회 — 캔들 데이터 기반 분석"""
    if exchange == "upbit":
        candles = await get_candles(market, unit=1, count=100)
    else:
        candles = await get_klines(market, interval="1m", limit=100)
    
    signal = generate_signal(candles)
    bot_state["signals"][market] = signal
    return signal


