# ─── 설정 파일 경로 ───
BOT_CONFIG_PATH = BASE_DIR / "bot_config.json"

def load_bot_config():
    if BOT_CONFIG_PATH.exists():
        try:
            with open(BOT_CONFIG_PATH, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            pass
    return {"enabled": False, "mode": "LIVE", "strategy": "RSI+MA"}

def save_bot_config(config):
    with open(BOT_CONFIG_PATH, "w", encoding="utf-8") as f:
        json.dump(config, f, indent=2, ensure_ascii=False)

# 봇 상태 초기화
saved_config = load_bot_config()
bot_state.update(saved_config)

# ─── 트레이딩 요청 모델 ───
class OrderRequest(BaseModel):
    market: str
    side: str        # "bid"=매수, "ask"=매도
    ord_type: str    # "price"=시장가매수, "market"=시장가매도, "limit"=지정가
    price: Optional[float] = None
    volume: Optional[float] = None

class KeyRequest(BaseModel):
    access_key: str
    secret_key: str

# ───────────────────────────────────────
# 실시간 데이터 캐시
# ───────────────────────────────────────
upbit_cache: dict = {}    # {market: ticker_data}
binance_cache: dict = {}  # {symbol: ticker_data}
connected_clients: list = []


async def broadcast(data: dict):
    """연결된 모든 WebSocket 클라이언트에 브로드캐스트"""
    dead = []
    for ws in connected_clients:
        try:
            await ws.send_json(data)
        except Exception:
            dead.append(ws)
    for ws in dead:
        connected_clients.remove(ws)


async def upbit_ticker_handler(data: dict):
    """업비트 WebSocket 수신 처리"""
    market = data.get("cd") or data.get("code")
    if not market:
        return
    upbit_cache[market] = {
        "market": market,
        "price": data.get("tp", 0) or data.get("trade_price", 0),
        "change_rate": round((data.get("scr", 0) or data.get("signed_change_rate", 0)) * 100, 2),
        "change": data.get("c") or data.get("change"),
        "volume_24h": data.get("atv24h", 0) or data.get("acc_trade_volume_24h", 0),
        "source": "upbit"
    }
    await broadcast({"type": "ticker", "exchange": "upbit", "data": upbit_cache[market]})


async def binance_ticker_handler(data: dict):
    """바이낸스 WebSocket 수신 처리"""
    symbol = data.get("s", "")
    if not symbol:
        return
    prev_close = float(data.get("o", 1))
    current = float(data.get("c", 0))
    change_rate = round(((current - prev_close) / prev_close) * 100, 2) if prev_close else 0

    binance_cache[symbol] = {
        "symbol": symbol,
        "price": current,
        "change_rate": change_rate,
        "volume_24h": float(data.get("v", 0)),
        "source": "binance"
    }
    await broadcast({"type": "ticker", "exchange": "binance", "data": binance_cache[symbol]})


# ⚔️ [ PHOENIX EMPIRE: THE LEGION OF 10,000 JAMS ] ⚔️
# 1만 명의 기동 대원이 동시 다발적으로 시장을 타격하는 군단 시스템입니다.
async def phoenix_quantum_loop():
    logger.info("⚔️ [PHOENIX] THE LEGION OF 10,000 JAMS IS RISING. INITIALIZING SWARM...")
    
    # 군단 지휘관들 (Core Jams act as Commanders)
    commander_collector = CollectorJam()
    commander_guardian = RiskGuardianJam()
    commander_executor = ExecutorJam()

    # 군단 정보 (1만 명의 요원 상태)
    JAM_COUNT = 10000
    legion_agents = [
        {"id": f"JAM_{i:04d}", "bias": random.uniform(-0.1, 0.1), "reliability": random.uniform(0.7, 0.99)}
        for i in range(JAM_COUNT)
    ]

    while True:
        try:
            if not bot_state.get("enabled", False):
                await asyncio.sleep(5)
                continue

            # 1. 시장 데이터 수집 (Command-level Data)
            target_market = "KRW-BTC"
            real_data = upbit_cache.get(target_market) or commander_collector.collect_all(asset="BTC")
            current_price = real_data.get('price', 0)

            # 2. 군단 총동원령 (Swarm Analysis)
            # 1만 명의 요원이 각자의 bias를 가지고 판단을 내립니다.
            logger.info(f"🛰️ [SWARM] Deploying {JAM_COUNT} agents for market analysis...")
            
            async def agent_decision(agent):
                # 각 요원의 개별적 판단 (Strategist Logic 시뮬레이션)
                # 시세 + 요원 편향성(bias) + 무작위 노이즈
                sentiment_score = (real_data.get('rsi', 50) - 50) * 0.02 + agent["bias"]
                if sentiment_score < -0.3: return "BUY"
                if sentiment_score > 0.3: return "SELL"
                return "HOLD"

            # 비동기 병렬 처리로 1만 명의 의견을 수렴 (배치 처리로 부하 조절)
            batch_size = 1000
            decisions = []
            for i in range(0, JAM_COUNT, batch_size):
                batch = legion_agents[i:i+batch_size]
                batch_results = await asyncio.gather(*(agent_decision(a) for a in batch))
                decisions.extend(batch_results)

            # 3. 집단 지성 합의 (Swarm Consensus)
            buy_votes = decisions.count("BUY")
            sell_votes = decisions.count("SELL")
            hold_votes = decisions.count("HOLD")
            
            consensus = "HOLD"
            if buy_votes > sell_votes and buy_votes > (JAM_COUNT * 0.1): # 10% 이상 찬성 시
                consensus = "BUY"
            elif sell_votes > buy_votes and sell_votes > (JAM_COUNT * 0.1):
                consensus = "SELL"

            # 군단 현황 방송
            await broadcast({
                "type": "swarm_report",
                "total_agents": JAM_COUNT,
                "votes": {"BUY": buy_votes, "SELL": sell_votes, "HOLD": hold_votes},
                "consensus": consensus,
                "price": current_price
            })

            # 4. 결 정에 따른 제국 타격 (Imperial Strike)
            if consensus != "HOLD":
                logger.info(f"🔥 [SWARM CONSENSUS] {consensus} DETECTED! (B:{buy_votes}, S:{sell_votes})")
                
                # 리스크 가디언의 최종 승인
                risk_check = commander_guardian.assess_risk(real_data)
                if risk_check.get('status') == "SAFE":
                    # 집단 지성 기반의 주문 집행
                    side = "bid" if consensus == "BUY" else "ask"
                    # 투표율에 비례하여 자금 할당 (많은 대원이 찬성할수록 더 큰 베팅)
                    vote_ratio = max(buy_votes, sell_votes) / JAM_COUNT
                    base_volume = 0.001 # 예시 수량
                    final_volume = base_volume * (vote_ratio * 10) 

                    order_res = await place_order(
                        market=target_market,
                        side=side,
                        ord_type="limit" if side == "bid" else "market",
                        price=current_price if side == "bid" else None,
                        volume=final_volume
                    )
                    
                    # 지휘관 엑스큐터의 최종 보고서
                    report = commander_executor.execute(
                        {"asset": "BTC", "action": consensus}, 
                        current_price, final_volume, risk_check.get('risk_score')
                    )
                    await broadcast({"type": "imperial_action", "report": report, "order_res": order_res})
                else:
                    logger.warning(f"🚫 [SWARM BLOCKED] Risk Guardian vetoed the consensus.")

            # 제국 표준 주기 (군단 재정비 시간)
            await asyncio.sleep(20)
        except Exception as e:
            logger.error(f"❌ [LEGION ERROR] Swarm Coordination Failure: {e}")
            await asyncio.sleep(10)

# ───────────────────────────────────────
# 앱 시작 시 백그라운드 스트리밍 및 군단 가동
# ───────────────────────────────────────
async def lifespan(app: FastAPI):
    logger.info("🚀 [PHOENIX] KOREA AI TRADING HUB INITIALIZED...")
    
    # 1. 시세 스트리밍 가동
    asyncio.create_task(stream_tickers(UPBIT_MARKETS, upbit_ticker_handler))
    asyncio.create_task(stream_mini_tickers(BINANCE_SYMBOLS, binance_ticker_handler))
    
    # 2. 글로벌 분석 주기적 실행 (5분마다)
    async def periodic_analysis():
        while True:
            await global_analyzer.run_analysis()
            await broadcast({"type": "global_insight", "data": global_analyzer.results})
            await asyncio.sleep(300)
    asyncio.create_task(periodic_analysis())

    # 3. ⚔️ 1만 명의 군단(Jam Swarm) 전투 개시
    asyncio.create_task(phoenix_quantum_loop())
    
    yield
    logger.info("🛑 [PHOENIX] SYSTEM SHUTDOWN.")


