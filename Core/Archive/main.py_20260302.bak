@app.post("/api/ai/toggle")
async def api_ai_toggle():
    bot_state["enabled"] = not bot_state["enabled"]
    save_bot_config({
        "enabled": bot_state["enabled"],
        "mode": bot_state["mode"],
        "strategy": bot_state["strategy"]
    })
    status = "ON" if bot_state["enabled"] else "OFF"
    return {"enabled": bot_state["enabled"], "message": f"AI 자동매매 {status}"}


@app.post("/api/ai/mode")
async def api_ai_mode(mode: str):
    """SIMULATION / LIVE 모드 전환"""
    if mode not in ["SIMULATION", "LIVE"]:
        return {"error": "Invalid mode"}
    bot_state["mode"] = mode
    save_bot_config({
        "enabled": bot_state["enabled"],
        "mode": bot_state["mode"],
        "strategy": bot_state["strategy"]
    })
    return {"mode": bot_state["mode"], "message": f"모드가 {mode}로 변경되었습니다."}


@app.get("/api/global/insight")
async def api_global_insight(q: str = None):
    """글로벌 분석 결과 조회 및 검색"""
    results = list(global_analyzer.results.values())
    if q:
        q = q.upper()
        results = [r for r in results if q in r["site"] or q in r["sentiment"]]
    return results


